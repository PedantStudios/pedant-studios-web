---
const year = new Date().getFullYear();
---

<footer class="border-t border-zinc-200 dark:border-zinc-800 mt-24">
  <div class="max-w-6xl mx-auto px-4 py-12 grid gap-8 md:grid-cols-4">
    <div class="md:col-span-2">
      <p class="font-bold text-zinc-900 dark:text-zinc-100">Pedant Studios</p>
      <p class="text-sm text-zinc-600 dark:text-zinc-400 mt-2 max-w-md">
        Small, focused software for tax preparation, bookkeeping, and similar small-firm workflows.
      </p>
    </div>

    <div>
      <p class="text-xs uppercase tracking-wider text-zinc-500 dark:text-zinc-500 font-semibold">Products</p>
      <ul class="mt-3 space-y-2 text-sm">
        <li><a href="/webcenter" class="no-underline text-zinc-700 hover:text-zinc-900 dark:text-zinc-300 dark:hover:text-zinc-100">WebCenter</a></li>
        <li><a href="https://docs.pedantstudios.com" class="no-underline text-zinc-700 hover:text-zinc-900 dark:text-zinc-300 dark:hover:text-zinc-100">Documentation</a></li>
      </ul>
    </div>

    <div>
      <p class="text-xs uppercase tracking-wider text-zinc-500 dark:text-zinc-500 font-semibold">Company</p>
      <ul class="mt-3 space-y-2 text-sm">
        <li><a href="/contact" class="no-underline text-zinc-700 hover:text-zinc-900 dark:text-zinc-300 dark:hover:text-zinc-100">Contact</a></li>
        <li><a href="/privacy" class="no-underline text-zinc-700 hover:text-zinc-900 dark:text-zinc-300 dark:hover:text-zinc-100">Privacy</a></li>
        <li><a href="/terms" class="no-underline text-zinc-700 hover:text-zinc-900 dark:text-zinc-300 dark:hover:text-zinc-100">Terms</a></li>
      </ul>
    </div>
  </div>

  <div class="border-t border-zinc-200 dark:border-zinc-800">
    <div class="max-w-6xl mx-auto px-4 py-6 text-xs text-zinc-500 dark:text-zinc-500 flex justify-between items-center flex-wrap gap-2">
      <p>© {year} Pedant Studios LLC. All rights reserved.</p>
      <p>Built carefully in spare time.</p>
    </div>
  </div>
</footer>
