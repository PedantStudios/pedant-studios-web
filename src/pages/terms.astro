---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = 'Terms of Service — Pedant Studios';
const description =
  'Terms governing use of Pedant Studios products and websites, including WebCenter.';

const lastUpdated = '2026-05-04';
---

<BaseLayout title={title} description={description} pathname="/terms">
  <Header />

  <main class="max-w-3xl mx-auto px-4 py-16 prose-content">
    <h1 class="text-4xl md:text-5xl font-bold text-zinc-900 dark:text-zinc-100 tracking-tight">
      Terms of Service
    </h1>
    <p class="mt-2 text-sm text-zinc-500 dark:text-zinc-500">Last updated: {lastUpdated}</p>

    <div class="mt-8 rounded-lg border border-amber-300 dark:border-amber-700 bg-amber-50 dark:bg-amber-900/20 p-4 text-sm text-amber-900 dark:text-amber-200">
      <strong>Placeholder.</strong> This is a stub terms of service intended only as a structural placeholder while final legal copy is being written. It is <strong>not legal advice</strong> and should not be relied on as a binding contract. The final terms will be published here.
    </div>

    <section class="mt-10 space-y-6 text-zinc-700 dark:text-zinc-300 leading-relaxed">
      <div>
        <h2 class="text-2xl font-bold text-zinc-900 dark:text-zinc-100">Provider</h2>
        <p class="mt-2">
          These terms are between you ("you" or "the firm") and Pedant Studios LLC ("Pedant Studios", "we", "us"). They cover use of pedantstudios.com, docs.pedantstudios.com, and our products including WebCenter.
        </p>
      </div>

      <div>
        <h2 class="text-2xl font-bold text-zinc-900 dark:text-zinc-100">What this stub will cover</h2>
        <p class="mt-2">The final terms will include:</p>
        <ul class="mt-3 list-disc pl-6 space-y-1">
          <li>Acceptable use — what you can and can't do with our products</li>
          <li>Account and security — your responsibility for credentials and authorized users</li>
          <li>Subscription and billing — payment, renewals, cancellation, refunds</li>
          <li>Beta and trial features — disclaimers about pre-release software</li>
          <li>Intellectual property — what's ours, what's yours, what's licensed</li>
          <li>Service availability and uptime expectations</li>
          <li>Data and privacy — how the privacy policy applies</li>
          <li>Liability limits and warranty disclaimers</li>
          <li>Termination — when and how either side can end the agreement</li>
          <li>Governing law and dispute resolution</li>
        </ul>
      </div>

      <div>
        <h2 class="text-2xl font-bold text-zinc-900 dark:text-zinc-100">Until the final terms are published</h2>
        <p class="mt-2">
          During beta, use of WebCenter is governed by these placeholder terms in spirit — use the product reasonably, don't try to attack or abuse it, and we'll make a good-faith effort to keep your data safe and the product working. If something goes wrong, contact us first; we resolve almost everything in conversation rather than escalation.
        </p>
      </div>

      <div>
        <h2 class="text-2xl font-bold text-zinc-900 dark:text-zinc-100">Contact</h2>
        <p class="mt-2">
          Questions about these terms: please <a href="/contact">contact us</a>.
        </p>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
