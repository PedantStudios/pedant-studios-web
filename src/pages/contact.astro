---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = 'Contact Pedant Studios';
const description =
  'Get in touch with Pedant Studios — questions about WebCenter, partnership inquiries, or general feedback. We respond within one business day.';
---

<BaseLayout title={title} description={description} pathname="/contact">
  <Header />

  <main class="max-w-3xl mx-auto px-4 py-16">
    <h1 class="text-4xl md:text-5xl font-bold text-zinc-900 dark:text-zinc-100 tracking-tight">
      Get in touch
    </h1>
    <p class="mt-4 text-lg text-zinc-700 dark:text-zinc-300">
      Questions about WebCenter, partnership inquiries, or general feedback —
      send us a message. We respond within one business day.
    </p>

    <form
      class="mt-10 space-y-6"
      data-contact-form
    >
      {/* Honeypot — bots fill this, real users don't see it */}
      <input
        type="text"
        name="website"
        tabindex="-1"
        autocomplete="off"
        class="absolute opacity-0 pointer-events-none -left-[9999px]"
        aria-hidden="true"
      />

      <div>
        <label for="name" class="block text-sm font-medium text-zinc-900 dark:text-zinc-100">
          Your name
        </label>
        <input
          id="name"
          name="name"
          type="text"
          required
          autocomplete="name"
          class="mt-2 block w-full px-4 py-3 rounded-lg border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-950 text-zinc-900 dark:text-zinc-100 placeholder-zinc-500 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
        />
      </div>

      <div>
        <label for="email" class="block text-sm font-medium text-zinc-900 dark:text-zinc-100">
          Email address
        </label>
        <input
          id="email"
          name="email"
          type="email"
          required
          autocomplete="email"
          class="mt-2 block w-full px-4 py-3 rounded-lg border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-950 text-zinc-900 dark:text-zinc-100 placeholder-zinc-500 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
        />
      </div>

      <div>
        <label for="topic" class="block text-sm font-medium text-zinc-900 dark:text-zinc-100">
          Topic
        </label>
        <select
          id="topic"
          name="topic"
          class="mt-2 block w-full px-4 py-3 rounded-lg border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-950 text-zinc-900 dark:text-zinc-100 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
        >
          <option value="general">General question</option>
          <option value="webcenter">WebCenter support</option>
          <option value="partnership">Partnership / integration</option>
          <option value="press">Press / media</option>
          <option value="other">Other</option>
        </select>
      </div>

      <div>
        <label for="message" class="block text-sm font-medium text-zinc-900 dark:text-zinc-100">
          Message
        </label>
        <textarea
          id="message"
          name="message"
          rows="6"
          required
          class="mt-2 block w-full px-4 py-3 rounded-lg border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-950 text-zinc-900 dark:text-zinc-100 placeholder-zinc-500 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent"
        ></textarea>
      </div>

      <div>
        <button
          type="submit"
          class="px-6 py-3 rounded-lg bg-brand-700 text-white font-semibold hover:bg-brand-800 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:ring-offset-2 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
        >
          Send message
        </button>
        <p class="mt-3 text-sm text-zinc-500 dark:text-zinc-500" data-contact-status role="status" aria-live="polite"></p>
      </div>
    </form>

    <div class="mt-16 pt-8 border-t border-zinc-200 dark:border-zinc-800 text-sm text-zinc-600 dark:text-zinc-400">
      <p>
        For WebCenter product help, the fastest path is the
        <a href="https://docs.pedantstudios.com/docs/webcenter/troubleshooting/common-issues">
          troubleshooting guide
        </a>
        — covers the most common questions. If you're already a WebCenter
        customer, you can also reach support directly from inside the app.
      </p>
    </div>
  </main>

  <Footer />

  <script>
    document.querySelectorAll<HTMLFormElement>('[data-contact-form]').forEach((form) => {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const status = form.querySelector<HTMLElement>('[data-contact-status]');
        const button = form.querySelector<HTMLButtonElement>('button[type="submit"]');
        const honeypot = form.querySelector<HTMLInputElement>('input[name="website"]');

        if (!status || !button) return;
        if (honeypot?.value) return;

        const formData = new FormData(form);
        const payload = {
          name: String(formData.get('name') || ''),
          email: String(formData.get('email') || ''),
          topic: String(formData.get('topic') || 'general'),
          message: String(formData.get('message') || ''),
        };

        button.disabled = true;
        status.textContent = 'Sending…';
        status.style.color = '';

        try {
          const res = await fetch('/api/contact', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });

          if (!res.ok) {
            const data = await res.json().catch(() => ({}));
            throw new Error(data.error || 'Send failed');
          }

          status.textContent = "Got it — we'll respond within one business day.";
          status.style.color = 'rgb(22 163 74)';
          form.reset();
        } catch (err) {
          status.textContent =
            err instanceof Error
              ? `Couldn't send: ${err.message}`
              : "Something went wrong. Please try again.";
          status.style.color = 'rgb(220 38 38)';
        } finally {
          button.disabled = false;
        }
      });
    });
  </script>
</BaseLayout>
