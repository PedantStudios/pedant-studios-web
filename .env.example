# Resend — https://resend.com/api-keys
# Used by /api/subscribe (email signup) and /api/contact (contact form).
RESEND_API_KEY=

# Verified sender on a domain you own in Resend, e.g. noreply@pedantstudios.com
RESEND_FROM_EMAIL=

# Resend Topic IDs. Topics are Resend's recipient-controlled subscription
# model — each topic represents an email category that contacts can opt in or
# out of independently. Create both at https://resend.com/topics
#
# Recommended setup:
#   - "Pedant Studios updates" → general topic
#   - "WebCenter updates" → webcenter topic
# Both should be opt-in default, public visibility.
RESEND_TOPIC_ID_GENERAL=
RESEND_TOPIC_ID_WEBCENTER=

# Where contact-form messages and new-subscriber notifications are emailed.
# Server-side only — never exposed to the page. Use whatever inbox you read.
CONTACT_TO_EMAIL=
