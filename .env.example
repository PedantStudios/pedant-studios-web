# Resend — https://resend.com/api-keys
# Used by /api/subscribe (email signup) and /api/contact (contact form).
RESEND_API_KEY=

# Verified sender on a domain you own in Resend, e.g. noreply@pedantstudios.com
RESEND_FROM_EMAIL=

# Resend Audience ID for the *general* email-signup list (homepage form).
# Create at https://resend.com/audiences
RESEND_AUDIENCE_ID=

# Resend Audience ID for the *WebCenter waitlist* (used by the WebCenter page form).
# If unset, WebCenter signups fall back to RESEND_AUDIENCE_ID — but you should
# set this to honor the implicit promise that WebCenter subscribers won't get
# unrelated cross-portfolio email.
RESEND_AUDIENCE_ID_WEBCENTER=

# Where contact-form submissions are emailed to. Server-side only — never exposed
# to the page. Use whatever inbox you actually read.
CONTACT_TO_EMAIL=
